<preamble>
% default font Arial like
\usepackage{helvet}
\renewcommand{\familydefault}{\sfdefault}

% use seeblau en-dash as default itemize item
\def\labelitemi{\textcolor{kn_seeblau}{--}}

% make underline seeblau
\usepackage{soul}
\setulcolor{kn_seeblau}
\setul{2.5pt}{0.125ex}

% custom commands: 
% &apos;subheader&apos; for topic divisions on the same page
\newcommand{\subheader}[1]{\textbf{\textcolor{kn_seeblau_65}{#1}}}
% &apos;define&apos; for new key terms
\newcommand{\define}[1]{\emph{\ul{#1}}}

% useful packages
\usepackage[utf8]{inputenc}
\usepackage{amsmath,amssymb}
\usepackage[shortlabels]{enumitem}
\usepackage[linesnumbered, ruled, vlined]{algorithm2e}
\SetKw{KwAnd}{and}
\SetKw{KwOr}{or}
\SetKw{KwReturn}{return}
\DontPrintSemicolon

% Copied from default presentation style sheet
\renewcommand\rmdefault{cmss}
\makeatletter
\leftmargini 1.5em
\leftmargin \leftmargini
\leftmarginii  1.2em
\leftmarginiii 1em
\def\@listI{\leftmargin\leftmargini
            \parsep \z@
	    \partopsep 3pt
	    \topsep \z@
            \itemsep \z@}
\@listI
\def\@listii {\leftmargin\leftmarginii
              \labelwidth\leftmarginii
              \advance\labelwidth-\labelsep
              \topsep    \z@
              \parsep    \z@
              \itemsep   \parsep}
\def\@listiii{\leftmargin\leftmarginiii
              \labelwidth\leftmarginiii
              \advance\labelwidth-\labelsep
              \topsep    \z@
              \parsep    \z@
              \partopsep \z@
              \itemsep   \topsep}
\makeatother
</preamble>
