<use layer="alpha" name="titlePage"/>
<text matrix="-2.32968 0 0 -22.7932 4554.68 4844.4" transformations="translations" pos="1536 208" stroke="kn_grau" type="label" width="703.714" height="39.6275" depth="12.155" valign="baseline">To go to the next page, press</text>
<text matrix="1 0 0 1 1105.76 -107.218" transformations="translations" pos="368 144" stroke="kn_seegruen" type="label" width="206.245" height="39.6275" depth="12.155" valign="baseline">PgDown</text>
<text layer="beta" matrix="1.48643 0.449035 -0.762606 1.46873 -581.391 -805.936" transformations="rigid" pos="1388.84 298.717" stroke="kn_grau" type="minipage" width="538.226" height="75.625" depth="48.29" valign="baseline" size="script">Action instructions are in grey, \\shortcuts will be shown \\in \textcolor{kn_seegruen}{seegrün}</text>
<path stroke="kn_seegruen" arrow="normal/normal">
1451.28 281.105 m
1558.55 220.265
1661.02 249.084
1736.27 172.234
1745.87 90.5802
1701.04 61.7613 c
</path>
</page>
<page section="What is IPE and why you should use it!">
<layer name="alpha"/>
<view layers="alpha" active="alpha"/>
<text layer="alpha" matrix="1 0 0 1 0 -352" pin="h" transformations="translations" pos="0 770" stroke="kn_seeblau" type="minipage" width="1680" height="58.036" depth="30.635" valign="top" size="LARGE">What is IPE and why you should use it!</text>
<text matrix="1 0 0 1 -1392 -59.2178" transformations="translations" pos="1392 96" stroke="kn_seegruen" type="label" width="137.038" height="39.6275" depth="12.155" valign="baseline">PgUp</text>
<text matrix="-2.32968 0 0 -22.7932 3578.39 4844.4" transformations="translations" pos="1536 208" stroke="kn_grau" type="label" width="807.224" height="39.6275" depth="12.155" valign="baseline">To go to the previous page, press</text>
</page>
<page title="What is IPE?" subsection="">
<layer name="alpha"/>
<view layers="alpha" active="alpha"/>
<text layer="alpha" pin="h" transformations="translations" pos="0 770" stroke="black" type="minipage" width="1680" height="187.154" depth="160.05" valign="top" style="itemize">\item At its core, IPE is a drawing editor
\item It can be used to \ul{create professional figures} (e.g. for a thesis)
\item \ul{Presentations} like this one (or for your seminar/colloquium...or Prof. Storandt&apos;s lecture slides) can easily be created as well
\item IPE is a tool specifically aimed at the scientific community</text>
<group>
<text matrix="1 0 0 1 -389.893 -6.4042" transformations="translations" pos="663.564 258.69" stroke="kn_grau" type="minipage" width="1073.85" height="66.8085" depth="39.435" valign="baseline">Annoyed by the grid and green boxes?\\
Press</text>
<text matrix="1 0 0 1 -92.098 -5.54509" transformations="translations" pos="798.052 226.669" stroke="kn_grau" type="label" width="560.758" height="40.4195" depth="12.155" valign="baseline">to toggle the grid on/off</text>
<text matrix="1 0 0 1 -130.523 -17.9877" transformations="translations" pos="836.477 172.234" stroke="kn_grau" type="label" width="700.375" height="39.6275" depth="12.155" valign="baseline">to toggle the bounding boxes</text>
<text matrix="1 0 0 1 74.1873 19.2126" transformations="translations" pos="433.013 196.249" stroke="kn_seegruen" type="label" width="94.4075" height="39.589" depth="0" valign="baseline">F12</text>
<text matrix="1 0 0 1 -7.24243 33.622" transformations="translations" pos="455.427 114.596" stroke="kn_seegruen" type="label" width="212.438" height="40.4085" depth="0.88" valign="baseline">Ctrl+F12</text>
</group>
</page>
<page title="What makes IPE so useful" subsection="">
<layer name="alpha"/>
<layer name="beta"/>
<layer name="gamma"/>
<view layers="alpha" active="alpha"/>
<view layers="alpha beta" active="beta"/>
<view layers="gamma" active="gamma"/>
<text layer="alpha" pin="h" transformations="translations" pos="0 770" stroke="black" type="minipage" width="1680" height="255.794" depth="228.91" valign="top" style="itemize">\item IPE not only features useful drawing tools and snapping modes, but also has \ul{full \LaTeX $\ $support!}
\item Any text or label you add to your figures and presentations is interpreteted as \LaTeX \ text
\item This means that, for example, adding \ul{equations} like \\$\sum_{i=1}^nn^2 =$ ? (I forgot the formula) is easy
\item Same goes for \ul{pseudocode}:</text>
<text matrix="1 0 0 1 -979.842 -95.3504" transformations="translations" pos="1065.43 257.089" stroke="black" type="minipage" width="658.425" height="100.617" depth="73.37" valign="baseline">\For{$i = 1 \ldots n$}
{
      $sum = sum + i^2$
}
\KwReturn{sum}</text>
<text layer="beta" matrix="0.997978 -0.0635609 0.0635609 0.997978 -286.08 33.0785" transformations="rigid" pos="1143.88 228.27" stroke="kn_grau" type="minipage" width="752.831" height="139.568" depth="112.42" valign="baseline" size="footnote">Check it out yourself: Select (\textcolor{kn_seegruen}{S} for selection mode) the list with the \textcolor{kn_seegruen}{left mouse}, go to the \emph{context menu} with the \textcolor{kn_seegruen}{right mouse} and select \emph{Edit text}.\\
See the \LaTeX \ commands?</text>
<text layer="gamma" pin="h" transformations="translations" pos="0 770" stroke="black" type="minipage" width="1680" height="214.588" depth="187.55" valign="top" style="itemize">\item Basically, with IPE you get the \ul{power for scientific notation} and tools provided by \LaTeX
\item But at the same time, also the \ul{ease of visual arrangement} and tuning that drawing programs offer
\item For presentations, IPE is sort of a sweetspot between Latex Beamer and Powerpoint</text>
<use matrix="1 0 0 1 -179.318 -1.60105" name="mark/disk(sx)" pos="164.036 218.664" size="normal" stroke="black"/>
