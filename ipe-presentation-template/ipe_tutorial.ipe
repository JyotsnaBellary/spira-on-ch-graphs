<text matrix="1 0 0 1 -55.3075 -9.79275" transformations="translations" pos="64 528" stroke="black" type="label" width="129.421" height="20.0255" depth="0.44" valign="baseline" size="tiny">consists of</text>
</group>
<group matrix="1 0 0 1 29.2299 63.0908">
<path matrix="1.33333 0 0 1.33333 -53.3333 -112" stroke="black" dash="dotted" arrow="normal/small">
