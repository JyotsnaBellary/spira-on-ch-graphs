<text matrix="1 0 0 1 196.553 -9.15136" transformations="translations" pos="844.101 139.859" stroke="kn_grau" type="minipage" width="308.994" height="60.423" depth="33.055" valign="top" size="footnote">Draw your own graph here:</text>
