{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug ERP CLI",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/Debug/erp_cli",
      "args": [],
      "cwd": "${workspaceFolder}",
      "MIMode": "gdb",
      "miDebuggerPath": "/usr/bin/gdb",
      "externalConsole": false,
      "stopAtEntry": false,
      "preLaunchTask": "Build (Debug)",
      "environment": [
        { "name": "ASAN_OPTIONS", "value": "detect_leaks=0" }
      ],
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ]
    }
  ]
}
